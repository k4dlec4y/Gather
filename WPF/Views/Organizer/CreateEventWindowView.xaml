<Window
	x:Class="WPF.Views.Organizer.CreateEventWindowView"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:local="clr-namespace:WPF.Views.Organizer"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
	Title="Create New Event"
	Width="800"
	Height="450"
	mc:Ignorable="d">
	<Grid Margin="10">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
			<RowDefinition Height="Auto" />
		</Grid.RowDefinitions>
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="Auto" />
			<ColumnDefinition Width="*" />
		</Grid.ColumnDefinitions>

		<Label
			Grid.Row="0"
			Grid.Column="0"
			Margin="0,0,5,5"
			Content="Event Name:" />
		<TextBox
			Grid.Row="0"
			Grid.Column="1"
			Margin="0,0,0,5"
			Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />

		<Label
			Grid.Row="1"
			Grid.Column="0"
			Margin="0,0,5,5"
			Content="Description:" />
		<TextBox
			Grid.Row="1"
			Grid.Column="1"
			Height="60"
			Margin="0,0,0,5"
			AcceptsReturn="True"
			Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
			TextWrapping="Wrap" />

		<Label
			Grid.Row="2"
			Grid.Column="0"
			Margin="0,0,5,5"
			Content="Image Path:" />
		<Grid
			Grid.Row="2"
			Grid.Column="1"
			Margin="0,0,0,5">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="*" />
				<ColumnDefinition Width="Auto" />
			</Grid.ColumnDefinitions>
			<TextBox Grid.Column="0" Text="{Binding ImageName, UpdateSourceTrigger=PropertyChanged}" />
			<Button
				Grid.Column="1"
				Width="75"
				Margin="5,0,0,0"
				Command="{Binding BrowseImageCommand}"
				Content="Browse..." />
		</Grid>

		<Label
			Grid.Row="3"
			Grid.Column="0"
			Margin="0,0,5,5"
			Content="Date:" />
		<xctk:DateTimePicker
			Grid.Row="3"
			Grid.Column="1"
			Margin="0,0,0,5"
			Format="FullDateTime"
			TimeFormatString="hh:mm tt"
			TimeWatermark="Select time"
			Value="{Binding Date}" />

		<Label
			Grid.Row="4"
			Grid.Column="0"
			Margin="0,0,5,5"
			Content="Location:" />
		<TextBox
			Grid.Row="4"
			Grid.Column="1"
			Margin="0,0,0,5"
			Text="{Binding Location, UpdateSourceTrigger=PropertyChanged}" />

		<Label
			Grid.Row="5"
			Grid.Column="0"
			Margin="0,0,5,5"
			Content="Categories (comma-separated):" />
		<TextBox
			Grid.Row="5"
			Grid.Column="1"
			Margin="0,0,0,5"
			Text="{Binding CategoriesInput, UpdateSourceTrigger=PropertyChanged}" />

		<StackPanel
			Grid.Row="7"
			Grid.ColumnSpan="2"
			HorizontalAlignment="Right"
			Orientation="Horizontal">
			<Button
				Width="80"
				Command="{Binding CreateCommand}"
				Content="Create" />
		</StackPanel>
	</Grid>
</Window>
