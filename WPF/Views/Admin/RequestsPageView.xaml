<Page
	x:Class="WPF.Views.Admin.RequestsPageView"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:local="clr-namespace:WPF.Views.Admin"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	Title="RequestsPageView"
	d:DesignHeight="450"
	d:DesignWidth="800"
	mc:Ignorable="d">

	<StackPanel Margin="10" Orientation="Vertical">
		<Border
			Margin="0,0,0,10"
			Padding="10"
			Background="#F0F0F0"
			CornerRadius="5">
			<Button
				Width="100"
				Padding="10,5"
				Command="{Binding ReloadRequestsCommand}"
				Content="Reload" />
		</Border>

		<ListBox
			Height="auto"
			BorderThickness="0"
			ItemsSource="{Binding BecomeOrganizerRequests}"
			ScrollViewer.VerticalScrollBarVisibility="Auto">
			<ListBox.ItemTemplate>
				<DataTemplate>
					<Border
						Padding="5"
						BorderBrush="LightGray"
						BorderThickness="0,0,0,1">
						<StackPanel Orientation="Horizontal">
							<TextBlock
								Width="200"
								VerticalAlignment="Center"
								FontSize="14"
								Text="{Binding User.Username}" />
							<TextBlock
								Width="200"
								VerticalAlignment="Center"
								FontSize="14"
								Text="{Binding RequestText}" />
							<Button
								Margin="10,0,0,0"
								Padding="5"
								Command="{Binding DataContext.AcceptRequestCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
								CommandParameter="{Binding}"
								Content="Accept" />
							<Button
								Margin="10,0,0,0"
								Padding="5"
								Command="{Binding DataContext.RejectRequestCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
								CommandParameter="{Binding}"
								Content="Reject" />
						</StackPanel>
					</Border>
				</DataTemplate>
			</ListBox.ItemTemplate>
		</ListBox>
	</StackPanel>
</Page>
