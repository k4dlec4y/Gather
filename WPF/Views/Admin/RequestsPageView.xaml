<Page
	x:Class="WPF.Views.Admin.RequestsPageView"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
	xmlns:local="clr-namespace:WPF.Views.Admin"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	Title="RequestsPageView"
	d:DesignHeight="800"
	d:DesignWidth="1400"
	Background="#FF0a0a0a"
	mc:Ignorable="d">

	<Page.Resources>
		<Style TargetType="TextBlock">
			<Setter Property="Foreground" Value="White" />
			<Setter Property="FontSize" Value="14" />
			<Setter Property="Margin" Value="0,5,0,5" />
		</Style>

		<Style TargetType="Button">
			<Setter Property="Background" Value="#FF7FFFD4" />
			<Setter Property="Foreground" Value="#FF1E1E2F" />
			<Setter Property="FontSize" Value="16" />
			<Setter Property="FontWeight" Value="Bold" />
			<Setter Property="Margin" Value="10,5" />
			<Setter Property="Padding" Value="10,5" />
			<Setter Property="BorderBrush" Value="Transparent" />
			<Setter Property="Cursor" Value="Hand" />
			<Setter Property="Effect">
				<Setter.Value>
					<DropShadowEffect
						BlurRadius="8"
						Opacity="0.6"
						ShadowDepth="0"
						Color="#FF7FFFD4" />
				</Setter.Value>
			</Setter>
			<Style.Triggers>
				<Trigger Property="IsMouseOver" Value="True">
					<Setter Property="Background" Value="#FF66E6B8" />
					<Setter Property="Effect">
						<Setter.Value>
							<DropShadowEffect
								BlurRadius="15"
								ShadowDepth="0"
								Color="#FF7FFFD4" />
						</Setter.Value>
					</Setter>
				</Trigger>
			</Style.Triggers>
		</Style>
	</Page.Resources>

	<Grid Background="#FF0a0a0a">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>

		<StackPanel
			Grid.Row="0"
			Margin="10"
			Orientation="Horizontal">
			<Button
				Width="auto"
				Command="{Binding ReloadRequestsCommand}"
				Content="Reload Requests" />
		</StackPanel>

		<ListBox
			Grid.Row="1"
			Margin="10"
			HorizontalContentAlignment="Stretch"
			Background="#FF1E1E2F"
			BorderBrush="#FF7FFFD4"
			BorderThickness="1"
			ItemsSource="{Binding BecomeOrganizerRequests}"
			ScrollViewer.VerticalScrollBarVisibility="Auto">
			<ListBox.ItemTemplate>
				<DataTemplate>
					<Border
						Margin="5"
						Padding="10"
						Background="#FF1E1E2F"
						Cursor="Arrow">
						<Grid VerticalAlignment="Center">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="200" />
								<ColumnDefinition Width="Auto" />
								<ColumnDefinition Width="*" />
								<ColumnDefinition Width="Auto" />
								<ColumnDefinition Width="Auto" />
							</Grid.ColumnDefinitions>

							<TextBlock
								Grid.Column="0"
								VerticalAlignment="Center"
								Foreground="White"
								Text="{Binding User.Username}" />

							<TextBlock
								Grid.Column="1"
								Margin="10,0"
								VerticalAlignment="Center"
								Foreground="White"
								Text="{Binding RequestText}" />

							<Button
								Grid.Column="3"
								Margin="10,0,0,0"
								Command="{Binding DataContext.AcceptRequestCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
								CommandParameter="{Binding}"
								Content="Accept" />

							<Button
								Grid.Column="4"
								Margin="10,0,0,0"
								Command="{Binding DataContext.RejectRequestCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
								CommandParameter="{Binding}"
								Content="Reject" />
						</Grid>
					</Border>
				</DataTemplate>
			</ListBox.ItemTemplate>
		</ListBox>
	</Grid>
</Page>
