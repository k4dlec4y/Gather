<UserControl x:Class="WPF.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="auto" Width="auto">
	<Grid Background="White">
		<ListBox x:Name="EventList"
                 BorderThickness="1"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 SelectionChanged="EventList_SelectionChanged">
			<ListBox.ItemTemplate>
				<DataTemplate>
					<Border BorderBrush="#DDD" BorderThickness="0 0 0 1" Padding="10" Margin="5" Cursor="Hand">
						<StackPanel Orientation="Horizontal" Margin="5">
							<Image Source="{Binding ImagePath}"
                                   Width="600" Height="480"
                                   Margin="0,0,10,0"
                                   Stretch="UniformToFill"/>
							<StackPanel>
								<TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="24"/>
								<TextBlock Text="{Binding Description}" TextWrapping="Wrap" FontSize="16" Foreground="Gray"/>
							</StackPanel>
						</StackPanel>
					</Border>
				</DataTemplate>
			</ListBox.ItemTemplate>
		</ListBox>
	</Grid>
</UserControl>