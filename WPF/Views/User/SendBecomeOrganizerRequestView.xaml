<Window
	x:Class="WPF.Views.UserV.SendBecomeOrganizerRequestView"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:local="clr-namespace:WPF.Views.UserV"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	Title="SendBecomeOrganizerRequest"
	Width="800"
	Height="460"
	WindowStartupLocation="CenterScreen"
	mc:Ignorable="d">
	<StackPanel Orientation="Vertical">
		<TextBlock
			Height="30"
			Margin="20,20,20,0"
			FontSize="16"
			Text="Describe who you are, what type of events would you like to organize, ..." />
		<TextBox
			Height="300"
			Margin="20,0,20,0"
			FontSize="13"
			Text="{Binding RequestText}" />
		<Button
			Width="150"
			Margin="20"
			Command="{Binding SendRequestCommand}"
			Content="Send request"
			FontSize="16" />
	</StackPanel>
</Window>
