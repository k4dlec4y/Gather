<Window
	x:Class="WPF.Views.UserV.MainView"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:local="clr-namespace:WPF.Views.UserV"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	Title="MainView"
	Width="1600"
	Height="800"
	Background="#FF000000"
	WindowStartupLocation="CenterScreen"
	mc:Ignorable="d">

	<Window.Resources>
		<Style TargetType="TextBlock">
			<Setter Property="Foreground" Value="White" />
			<Setter Property="FontSize" Value="14" />
			<Setter Property="Margin" Value="0,5,0,5" />
		</Style>

		<Style x:Key="CustomTextBoxStyle" TargetType="TextBox">
			<Setter Property="Background" Value="#FFFFFFFF" />
			<Setter Property="Foreground" Value="White" />
			<Setter Property="BorderBrush" Value="#FF7FFFD4" />
			<Setter Property="BorderThickness" Value="1" />
			<Setter Property="Height" Value="30" />
			<Setter Property="Margin" Value="0,0,0,15" />
			<Setter Property="Padding" Value="5" />
			<Setter Property="FocusVisualStyle" Value="{x:Null}" />
			<Style.Triggers>
				<Trigger Property="IsFocused" Value="True">
					<Setter Property="BorderBrush" Value="Red" />
				</Trigger>
			</Style.Triggers>
		</Style>

		<Style TargetType="Button">
			<Setter Property="Background" Value="#FFFF00FF" />
			<Setter Property="Foreground" Value="#FF000000" />
			<Setter Property="FontSize" Value="16" />
			<Setter Property="FontWeight" Value="Bold" />
			<Setter Property="Margin" Value="10,5" />
			<Setter Property="Padding" Value="10,5" />
			<Setter Property="BorderBrush" Value="Transparent" />
		</Style>
	</Window.Resources>

	<Grid>
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="220" />
			<ColumnDefinition Width="*" />
		</Grid.ColumnDefinitions>

		<StackPanel Grid.Column="0" Background="#FF000000">
			<TextBlock
				Margin="0,20,0,20"
				HorizontalAlignment="Center"
				FontSize="28"
				FontWeight="Bold"
				Text="GATHER">
				<TextBlock.Foreground>
					<LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
						<GradientStop Offset="0.3" Color="#FFFF00FF" />
						<GradientStop Offset="0.7" Color="#FF7FFFD4" />
					</LinearGradientBrush>
				</TextBlock.Foreground>
				<TextBlock.Effect>
					<DropShadowEffect
						BlurRadius="12"
						Opacity="0.8"
						ShadowDepth="0"
						Color="#FFFF00FF" />
				</TextBlock.Effect>
			</TextBlock>

			<Button
				x:Name="Events"
				Command="{Binding EventsCommand}"
				Content="Events" />
			<Button Command="{Binding FriendsCommand}" Content="Friends" />
			<Button Command="{Binding InboxCommand}" Content="Inbox" />
			<Button Command="{Binding SettingsCommand}" Content="Settings" />
		</StackPanel>

		<Frame
			x:Name="MainFrame"
			Grid.Column="1"
			Background="#FF000000"
			Content="{Binding CurrentPage}"
			NavigationUIVisibility="Hidden" />
	</Grid>
</Window>