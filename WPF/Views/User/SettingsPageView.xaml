<Page
	x:Class="WPF.Views.UserV.SettingsPageView"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:local="clr-namespace:WPF.Views.UserV"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	Title="SettingsPageView"
	d:DesignHeight="450"
	d:DesignWidth="800"
	Background="White"
	mc:Ignorable="d">

	<StackPanel
		Margin="20"
		HorizontalAlignment="Left"
		VerticalAlignment="Top">

		<Label
			HorizontalAlignment="Center"
			Content="Click the button below to sign out:"
			FontSize="16" />

		<Button
			Width="120"
			Height="40"
			Background="Tomato"
			Content="Sign Out"
			FontWeight="Bold"
			Foreground="White" />
	</StackPanel>
</Page>
