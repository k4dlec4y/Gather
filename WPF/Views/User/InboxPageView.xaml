<Page
	x:Class="WPF.Views.UserV.InboxPageView"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:local="clr-namespace:WPF.Views.UserV"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	Title="InboxPageView"
	d:DesignHeight="800"
	d:DesignWidth="1450"
	mc:Ignorable="d">

	<Grid>
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="*" />
		</Grid.ColumnDefinitions>

		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
		</Grid.RowDefinitions>
		<TextBlock
			Grid.Row="0"
			Grid.Column="0"
			Margin="10,10,0,5"
			FontWeight="Bold"
			Text="Received messages:" />
		<ListBox
			Grid.Row="1"
			Grid.Column="0"
			BorderThickness="0"
			ItemsSource="{Binding MainVM.CurrentUser.Inbox}"
			ScrollViewer.VerticalScrollBarVisibility="Auto">
			<ListBox.ItemTemplate>
				<DataTemplate>
					<Border
						Padding="5"
						BorderBrush="LightGray"
						BorderThickness="0,0,0,1">
						<StackPanel Orientation="Horizontal">
							<TextBlock
								Width="200"
								VerticalAlignment="Center"
								FontSize="18"
								Text="{Binding From.Username}" />
							<TextBlock
								Width="auto"
								VerticalAlignment="Center"
								FontSize="14"
								Text="{Binding Content}" />
						</StackPanel>
					</Border>
				</DataTemplate>
			</ListBox.ItemTemplate>
		</ListBox>

		<TextBlock
			Grid.Row="2"
			Grid.Column="0"
			Margin="10,10,0,5"
			FontWeight="Bold"
			Text="Received invites:" />
		<ListBox
			Grid.Row="3"
			Grid.Column="0"
			BorderThickness="0"
			ItemsSource="{Binding MainVM.CurrentUser.Invites}"
			ScrollViewer.VerticalScrollBarVisibility="Auto">
			<ListBox.ItemTemplate>
				<DataTemplate>
					<Border
						Padding="5"
						BorderBrush="LightGray"
						BorderThickness="0,0,0,1">
						<StackPanel Orientation="Horizontal">
							<TextBlock
								Width="200"
								VerticalAlignment="Center"
								FontSize="18"
								Text="{Binding From.Username}" />
							<TextBlock
								Width="auto"
								VerticalAlignment="Center"
								FontSize="14"
								Text="{Binding Content}" />
						</StackPanel>
					</Border>
				</DataTemplate>
			</ListBox.ItemTemplate>
		</ListBox>

		<TextBlock
			Grid.Row="4"
			Grid.Column="0"
			Margin="10,10,0,5"
			FontWeight="Bold"
			Text="Received friend requests:" />
		<ListBox
			Grid.Row="5"
			Grid.Column="0"
			Width="1450"
			BorderThickness="0"
			ItemsSource="{Binding MainVM.CurrentUser.FriendRequests}"
			ScrollViewer.VerticalScrollBarVisibility="Auto">
			<ListBox.ItemTemplate>
				<DataTemplate>
					<Border
						Padding="5"
						BorderBrush="LightGray"
						BorderThickness="0,0,0,1">
						<Grid>
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="200" />
								<ColumnDefinition Width="*" />
								<ColumnDefinition Width="Auto" />
								<ColumnDefinition Width="20" />
							</Grid.ColumnDefinitions>

							<TextBlock
								Grid.Column="0"
								Margin="5,0,0,0"
								HorizontalAlignment="Left"
								VerticalAlignment="Center"
								FontSize="18"
								Text="{Binding From.Username, StringFormat='From: {0}'}" />

							<TextBlock
								Grid.Column="1"
								Margin="5,0,0,0"
								HorizontalAlignment="Center"
								VerticalAlignment="Center"
								FontSize="14"
								Text="{Binding Content}" />

							<StackPanel
								Grid.Column="2"
								Grid.ColumnSpan="2"
								HorizontalAlignment="Right"
								VerticalAlignment="Center"
								Orientation="Horizontal">
								<Button
									Margin="5,0,0,0"
									Padding="10,5"
									Command="{Binding DataContext.AcceptFriendRequestCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
									CommandParameter="{Binding}"
									Content="Accept" />

								<Button
									Margin="5,0,0,0"
									Padding="10,5"
									Command="{Binding DataContext.RejectFriendRequestCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
									CommandParameter="{Binding}"
									Content="Reject" />
							</StackPanel>
						</Grid>
					</Border>
				</DataTemplate>
			</ListBox.ItemTemplate>
		</ListBox>
	</Grid>
</Page>
