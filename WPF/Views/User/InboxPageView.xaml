<Page
	x:Class="WPF.Views.UserV.InboxPageView"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:local="clr-namespace:WPF.Views.UserV"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	Title="InboxPageView"
	d:DesignHeight="800"
	d:DesignWidth="1450"
	Background="#FF0a0a0a"
	mc:Ignorable="d">

	<Page.Resources>
		<Style TargetType="TextBlock">
			<Setter Property="Foreground" Value="White" />
			<Setter Property="FontSize" Value="14" />
			<Setter Property="Margin" Value="0,5,0,5" />
		</Style>

		<Style TargetType="Button">
			<Setter Property="Background" Value="#FF7FFFD4" />
			<Setter Property="Foreground" Value="#FF1E1E2F" />
			<Setter Property="FontSize" Value="16" />
			<Setter Property="FontWeight" Value="Bold" />
			<Setter Property="Margin" Value="10,5" />
			<Setter Property="Padding" Value="10,5" />
			<Setter Property="BorderBrush" Value="Transparent" />
			<Setter Property="Cursor" Value="Hand" />
			<Setter Property="Effect">
				<Setter.Value>
					<DropShadowEffect
						BlurRadius="8"
						Opacity="0.6"
						ShadowDepth="0"
						Color="#FF7FFFD4" />
				</Setter.Value>
			</Setter>
			<Style.Triggers>
				<Trigger Property="IsMouseOver" Value="True">
					<Setter Property="Background" Value="#FF66E6B8" />
					<Setter Property="Effect">
						<Setter.Value>
							<DropShadowEffect
								BlurRadius="15"
								ShadowDepth="0"
								Color="#FF7FFFD4" />
						</Setter.Value>
					</Setter>
				</Trigger>
			</Style.Triggers>
		</Style>

		<Style TargetType="ListBox">
			<Setter Property="Background" Value="#FF0a0a0a" />
			<Setter Property="Foreground" Value="White" />
			<Setter Property="BorderThickness" Value="0" />
			<Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
		</Style>
	</Page.Resources>

	<Grid>
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="*" />
		</Grid.ColumnDefinitions>

		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
		</Grid.RowDefinitions>

		<TextBlock
			Grid.Row="0"
			Grid.Column="0"
			Margin="10,10,10,5"
			FontSize="20"
			FontWeight="Bold"
			Text="Received messages:" />
		<ListBox
			Grid.Row="1"
			Grid.Column="0"
			HorizontalContentAlignment="Stretch"
			BorderThickness="0"
			ItemsSource="{Binding MainVM.CurrentUser.Inbox}"
			ScrollViewer.VerticalScrollBarVisibility="Auto">
			<ListBox.ItemTemplate>
				<DataTemplate>
					<Border
						Padding="5"
						BorderBrush="#FF7FFFD4"
						BorderThickness="0,0,0,1">

						<Grid>
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="200" />
								<ColumnDefinition Width="Auto" />
								<ColumnDefinition Width="*" />
								<ColumnDefinition Width="Auto" />
								<ColumnDefinition Width="20" />
							</Grid.ColumnDefinitions>

							<TextBlock
								Grid.Column="0"
								Margin="5,0,0,0"
								VerticalAlignment="Center"
								FontSize="16"
								FontWeight="SemiBold"
								Text="{Binding From.Username, StringFormat='From: {0}'}" />

							<TextBlock
								Grid.Column="1"
								Margin="10,0,10,0"
								VerticalAlignment="Center"
								FontSize="14"
								Text="{Binding Content}"
								TextWrapping="Wrap" />

							<Button
								Grid.Column="3"
								Margin="5,0,0,0"
								Padding="10,5"
								Command="{Binding DataContext.DeleteMessageCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
								CommandParameter="{Binding}"
								Content="Delete" />
						</Grid>
					</Border>
				</DataTemplate>
			</ListBox.ItemTemplate>
		</ListBox>

		<TextBlock
			Grid.Row="2"
			Grid.Column="0"
			Margin="10,10,10,5"
			FontSize="20"
			FontWeight="Bold"
			Text="Received invites:" />
		<ListBox
			Grid.Row="3"
			Grid.Column="0"
			HorizontalContentAlignment="Stretch"
			BorderThickness="0"
			ItemsSource="{Binding MainVM.CurrentUser.Invites}"
			ScrollViewer.VerticalScrollBarVisibility="Auto">
			<ListBox.ItemTemplate>
				<DataTemplate>
					<Border
						Padding="5"
						BorderBrush="#FF7FFFD4"
						BorderThickness="0,0,0,1">
						<Grid>
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="200" />
								<ColumnDefinition Width="Auto" />
								<ColumnDefinition Width="*" />
								<ColumnDefinition Width="Auto" />
								<ColumnDefinition Width="20" />
							</Grid.ColumnDefinitions>

							<TextBlock
								Grid.Column="0"
								Margin="5,0,0,0"
								VerticalAlignment="Center"
								FontSize="16"
								FontWeight="SemiBold"
								Text="{Binding From.Username, StringFormat='From: {0}'}" />
							<TextBlock
								Grid.Column="1"
								Margin="10,0,10,0"
								VerticalAlignment="Center"
								FontSize="14"
								Text="{Binding Content}"
								TextWrapping="Wrap" />

							<StackPanel
								Grid.Column="3"
								HorizontalAlignment="Right"
								VerticalAlignment="Center"
								Orientation="Horizontal">
								<Button
									Margin="5,0,0,0"
									Padding="10,5"
									Command="{Binding DataContext.AcceptInviteCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
									CommandParameter="{Binding}"
									Content="Accept" />

								<Button
									Margin="5,0,0,0"
									Padding="10,5"
									Command="{Binding DataContext.RejectInviteCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
									CommandParameter="{Binding}"
									Content="Reject" />
							</StackPanel>
						</Grid>
					</Border>
				</DataTemplate>
			</ListBox.ItemTemplate>
		</ListBox>

		<TextBlock
			Grid.Row="4"
			Grid.Column="0"
			Margin="10,10,10,5"
			FontSize="20"
			FontWeight="Bold"
			Text="Received friend requests:" />
		<ListBox
			Grid.Row="5"
			Grid.Column="0"
			HorizontalContentAlignment="Stretch"
			BorderThickness="0"
			ItemsSource="{Binding MainVM.CurrentUser.FriendRequests}"
			ScrollViewer.VerticalScrollBarVisibility="Auto">
			<ListBox.ItemTemplate>
				<DataTemplate>
					<Border
						Padding="5"
						BorderBrush="#FF7FFFD4"
						BorderThickness="0,0,0,1">
						<Grid>
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="200" />
								<ColumnDefinition Width="Auto" />
								<ColumnDefinition Width="*" />
								<ColumnDefinition Width="Auto" />
								<ColumnDefinition Width="20" />
							</Grid.ColumnDefinitions>

							<TextBlock
								Grid.Column="0"
								Margin="5,0,0,0"
								VerticalAlignment="Center"
								FontSize="16"
								FontWeight="SemiBold"
								Text="{Binding From.Username, StringFormat='From: {0}'}" />

							<TextBlock
								Grid.Column="1"
								Margin="10,0,10,0"
								VerticalAlignment="Center"
								FontSize="14"
								Text="{Binding Content}"
								TextWrapping="Wrap" />

							<StackPanel
								Grid.Column="3"
								HorizontalAlignment="Right"
								VerticalAlignment="Center"
								Orientation="Horizontal">
								<Button
									Margin="5,0,0,0"
									Padding="10,5"
									Command="{Binding DataContext.AcceptFriendRequestCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
									CommandParameter="{Binding}"
									Content="Accept" />

								<Button
									Margin="5,0,0,0"
									Padding="10,5"
									Command="{Binding DataContext.RejectFriendRequestCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
									CommandParameter="{Binding}"
									Content="Reject" />
							</StackPanel>
						</Grid>
					</Border>
				</DataTemplate>
			</ListBox.ItemTemplate>
		</ListBox>
	</Grid>
</Page>
