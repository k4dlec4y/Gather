<Page
	x:Class="WPF.Views.UserV.EventsPageView"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
	xmlns:local="clr-namespace:WPF.Views.UserV"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	Title="EventsPageView"
	d:DesignHeight="450"
	d:DesignWidth="800"
	mc:Ignorable="d">

	<StackPanel Background="White">

		<StackPanel Orientation="Horizontal">
			<TextBox
				x:Name="SearchBox"
				Width="300"
				Height="20"
				Margin="10"
				VerticalAlignment="Top"
				Text="{Binding SearchQuery}" />
			<Button
				x:Name="SearchButton"
				Width="100"
				Height="20"
				Margin="10"
				VerticalAlignment="Top"
				Command="{Binding FilterEventsCommand}"
				Content="Search" />
			<CheckBox
				x:Name="EventsToParticipate"
				Margin="10"
				VerticalAlignment="Top"
				Command="{Binding FilterEventsCommand}"
				Content="Events I participate in"
				IsChecked="{Binding IsParticipatingOnly, Mode=TwoWay}" />
		</StackPanel>

		<ListBox
			x:Name="EventList"
			BorderThickness="1"
			ItemsSource="{Binding Events}"
			ScrollViewer.VerticalScrollBarVisibility="Visible"
			SelectedItem="{Binding SelectedEvent, Mode=TwoWay}">

			<i:Interaction.Triggers>
				<i:EventTrigger EventName="SelectionChanged">
					<i:InvokeCommandAction Command="{Binding SelectEventCommand}" />
				</i:EventTrigger>
			</i:Interaction.Triggers>

			<ListBox.ItemTemplate>
				<DataTemplate>
					<Border
						Margin="5"
						Padding="10"
						BorderBrush="#DDD"
						BorderThickness="0,0,0,1"
						Cursor="Hand">
						<StackPanel Margin="5" Orientation="Horizontal">
							<Image
								Width="400"
								Height="300"
								Margin="0,0,10,0"
								Source="{Binding ImagePath}"
								Stretch="Fill" />
							<StackPanel>
								<TextBlock
									FontSize="24"
									FontWeight="Bold"
									Text="{Binding Name}" />
								<StackPanel Margin="5" Orientation="Horizontal">
									<CheckBox
										Name="Participate"
										IsChecked="{Binding IsCurrentUserParticipating, Mode=TwoWay}"
										IsEnabled="False" />

									<Button
										Name="ChangeParticipation"
										Command="{Binding DataContext.ParticipateCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
										CommandParameter="{Binding}"
										Content="Change Participation" />

								</StackPanel>

								<Button
									Name="SendInvite"
									Margin="5"
									Command="{Binding DataContext.SendInviteCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
									CommandParameter="{Binding}"
									Content="Send Invite" />
								<TextBlock
									FontSize="16"
									Foreground="Gray"
									Text="{Binding Date}"
									TextWrapping="Wrap" />
								<TextBlock
									FontSize="16"
									Foreground="Gray"
									Text="{Binding Description}"
									TextWrapping="Wrap" />
								<TextBlock
									Margin="5,0,0,0"
									VerticalAlignment="Center"
									FontStyle="Italic"
									Text="{Binding Participants.Count, StringFormat=' ({0} participants)'}" />
							</StackPanel>
						</StackPanel>
					</Border>
				</DataTemplate>
			</ListBox.ItemTemplate>
		</ListBox>
	</StackPanel>
</Page>
