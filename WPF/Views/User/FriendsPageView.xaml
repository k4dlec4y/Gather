<Page
	x:Class="WPF.Views.UserV.FriendsPageView"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
	xmlns:local="clr-namespace:WPF.Views.UserV"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	Title="FriendsPageView"
	d:DesignHeight="800"
	d:DesignWidth="1400"
	Background="#FF0a0a0a"
	mc:Ignorable="d">

	<Page.Resources>
		<Style TargetType="TextBlock">
			<Setter Property="Foreground" Value="White" />
			<Setter Property="FontSize" Value="14" />
			<Setter Property="Margin" Value="0,5,0,5" />
		</Style>

		<Style TargetType="Button">
			<Setter Property="Background" Value="#FF7FFFD4" />
			<Setter Property="Foreground" Value="#FF1E1E2F" />
			<Setter Property="FontSize" Value="16" />
			<Setter Property="FontWeight" Value="Bold" />
			<Setter Property="Margin" Value="10,5" />
			<Setter Property="Padding" Value="10,5" />
			<Setter Property="BorderBrush" Value="Transparent" />
			<Setter Property="Cursor" Value="Hand" />
			<Setter Property="Effect">
				<Setter.Value>
					<DropShadowEffect
						BlurRadius="8"
						Opacity="0.6"
						ShadowDepth="0"
						Color="#FF7FFFD4" />
				</Setter.Value>
			</Setter>
			<Style.Triggers>
				<Trigger Property="IsMouseOver" Value="True">
					<Setter Property="Background" Value="#FF66E6B8" />
					<Setter Property="Effect">
						<Setter.Value>
							<DropShadowEffect
								BlurRadius="15"
								ShadowDepth="0"
								Color="#FF7FFFD4" />
						</Setter.Value>
					</Setter>
				</Trigger>
			</Style.Triggers>
		</Style>

		<Style TargetType="TextBox">
			<Setter Property="Background" Value="#FF1E1E2F" />
			<Setter Property="Foreground" Value="White" />
			<Setter Property="BorderBrush" Value="#FF7FFFD4" />
			<Setter Property="Margin" Value="10" />
			<Setter Property="Padding" Value="5" />
			<Setter Property="FontSize" Value="14" />
		</Style>
	</Page.Resources>

	<Grid Background="#FF0a0a0a">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>

		<StackPanel
			Margin="10"
			Background="#FF0a0a0a"
			Orientation="Horizontal">
			<TextBox
				x:Name="UsernameTextBox"
				Width="300"
				VerticalAlignment="Center"
				Text="{Binding NewFriendUsername, UpdateSourceTrigger=PropertyChanged}" />
			<Button
				Width="auto"
				Height="auto"
				Margin="10,0,0,0"
				Command="{Binding AddFriendCommand}"
				Content="Add Friend" />
		</StackPanel>

		<ListBox
			Grid.Row="1"
			Margin="10"
			HorizontalContentAlignment="Stretch"
			Background="#FF0a0a0a"
			BorderThickness="0"
			Foreground="White"
			ItemsSource="{Binding MainVM.CurrentUser.Friends}"
			ScrollViewer.VerticalScrollBarVisibility="Auto"
			SelectedItem="{Binding SelectedUser, Mode=TwoWay}">
			<ListBox.ItemTemplate>
				<DataTemplate>
					<Border
						Margin="5"
						Padding="15"
						Background="#FF0a0a0a"
						CornerRadius="5">
						<Grid>
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="Auto" />
								<ColumnDefinition Width="*" />
								<ColumnDefinition Width="Auto" />
							</Grid.ColumnDefinitions>

							<TextBlock
								Grid.Column="0"
								VerticalAlignment="Center"
								FontSize="16"
								Foreground="White"
								Text="{Binding Username}" />

							<Button
								Grid.Column="2"
								Command="{Binding DataContext.RemoveFriendCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
								CommandParameter="{Binding}"
								Content="Remove" />
						</Grid>
					</Border>
				</DataTemplate>
			</ListBox.ItemTemplate>
		</ListBox>
	</Grid>
</Page>
