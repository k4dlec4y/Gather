<Window x:Class="WPF.Views.UserMainWindowView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:views="clr-namespace:WPF.Views"
        Title="Gather" Height="1080" Width="1920">
	<Grid>
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="150"/>
			<ColumnDefinition Width="*"/>
		</Grid.ColumnDefinitions>

		<StackPanel Grid.Column="0" Background="LightGray">
			<Button Content="Home" Margin="5" Click="Home_Click"/>
			<Button Content="Friend List" Margin="5" Click="FriendList_Click"/>
			<Button Content="Settings" Margin="5" Click="Settings_Click"/>
		</StackPanel>

		<ContentControl x:Name="MainContentArea" Grid.Column="1"/>
	</Grid>
</Window>